# Normalize all text files to LF in the repo, regardless of OS.
# Working-tree checkouts on Windows will still get LF (since core.autocrlf=input).
# This prevents spurious CRLF/LF diffs and keeps shell scripts, hashes, and
# build attestations reproducible across platforms.

# Default: auto-detect text vs. binary, force LF for text.
* text=auto eol=lf

# Explicit text — be unambiguous about source files.
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.toml      text eol=lf
*.sh        text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf
LICENSE     text eol=lf

# Binary — never touch, never diff as text.
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.otf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.gz        binary
